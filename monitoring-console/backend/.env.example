# URL de l'API Loki (logs applicatifs + commandes IA)
LOKI_URL=http://localhost:3100

# URL de l'API Prometheus (metriques)
PROMETHEUS_URL=http://localhost:9090

# URL de l'API Argo CD (statut GitOps) + token d'acces.
# https, pas http : le tunnel "kubectl port-forward svc/argocd-server -n argocd 8080:443"
# sert du TLS auto-signe sur ce port. En dev, exporter aussi
# NODE_TLS_REJECT_UNAUTHORIZED=0 pour que Node accepte ce certificat.
ARGOCD_URL=https://localhost:8080
# Recuperer un token de session valide : "argocd login localhost:8080 --username admin
# --password $ARGOCD_ADMIN_PASSWORD --insecure" puis lire le champ auth-token dans
# ~/.config/argocd/config (un token de compte via "account generate-token" necessite
# la capability apiKey, non activee par defaut sur le compte admin).
ARGOCD_TOKEN=

# Port d'ecoute du backend
PORT=4000
